                            <canvas id="envChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Telemetry & Controls Column -->
                <div class="space-y-6 flex flex-col h-full">
                    
                    <!-- Live Metrics -->
                    <div class="glass-panel rounded-xl p-5">
                        <h2 class="font-bold text-slate-700 mb-4 uppercase text-xs tracking-wider">Real-time Telemetry</h2>
                        <div class="grid grid-cols-2 gap-4">
                            <!-- Moisture -->
                            <div class="bg-slate-50 rounded-lg p-4 border border-slate-200 relative overflow-hidden shadow-sm">
                                <div class="absolute -right-3 -top-3 text-blue-100 text-6xl"><i class="fa-solid fa-droplet"></i></div>
