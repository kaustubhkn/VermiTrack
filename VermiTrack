        <!-- DOCUMENTATION VIEW -->
        <div id="view-docs" class="max-w-4xl mx-auto hidden bg-white border border-slate-200 rounded-xl p-8 shadow-xl">
            
            <div class="border-b border-slate-100 pb-6 mb-8 text-center">
                <h1 class="text-3xl font-bold text-slate-800 mb-2">Productizing Sustainable Organic Waste Management</h1>
                <p class="text-emerald-600 font-medium">VermiTrack Complete Specification & Scientific Basis</p>
            </div>

            <div class="space-y-10 text-slate-600 leading-relaxed">
                
                <section>
                    <h2 class="text-xl font-bold text-slate-800 mb-4 border-l-4 border-emerald-500 pl-4 flex items-center">
                        <i class="fa-solid fa-leaf mr-3 text-emerald-500"></i>1. The Vermicompost Advantage
                    </h2>
                    <p class="mb-4">Vermicompost is the excreta of earthworms, rich in humus and essential plant nutrients. VermiTrack automates the environment for highly efficient species like <em>Eisenia foetida</em>, <em>Eudrillus eugineae</em>, and <em>Amyanthes differigens</em>.</p>
                    <ul class="grid grid-cols-1 md:grid-cols-2 gap-3 pl-2">
                        <li class="flex items-start"><i class="fa-solid fa-check text-emerald-500 mt-1 mr-3"></i><div>Rich in beneficial micro-flora (N-fixers, P-solubilizers, cellulose decomposing).</div></li>
                        <li class="flex items-start"><i class="fa-solid fa-check text-emerald-500 mt-1 mr-3"></i><div>Neutralizes soil pH and prevents nutrient losses.</div></li>
                        <li class="flex items-start"><i class="fa-solid fa-check text-emerald-500 mt-1 mr-3"></i><div>Free from pathogens, toxic elements, and weed seeds.</div></li>
                        <li class="flex items-start"><i class="fa-solid fa-check text-emerald-500 mt-1 mr-3"></i><div>Contains valuable vitamins, enzymes, and hormones (auxins, gibberellins).</div></li>
                        <li class="flex items-start"><i class="fa-solid fa-check text-emerald-500 mt-1 mr-3"></i><div>Minimizes the incidence of pests and diseases.</div></li>
                    </ul>
                </section>

                <section>
                    <h2 class="text-xl font-bold text-slate-800 mb-4 border-l-4 border-blue-500 pl-4 flex items-center">
                        <i class="fa-solid fa-flask mr-3 text-blue-500"></i>2. Guaranteed Nutrient Profile
                    </h2>
                    <p class="mb-4">By strictly monitoring and processing bio-degradable inputs (crop residues, weed bio-mass, vegetable waste, leaf litter, etc.), VermiTrack guarantees a high-grade nutrient output consistent with agricultural standards:</p>
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 font-mono text-sm">
                        <div class="bg-slate-50 p-3 rounded border border-slate-200"><strong class="text-slate-800">Nitrogen (N):</strong> 1.5 - 2.5%</div>
                        <div class="bg-slate-50 p-3 rounded border border-slate-200"><strong class="text-slate-800">Phosphorus (P):</strong> 0.9 - 1.7%</div>
                        <div class="bg-slate-50 p-3 rounded border border-slate-200"><strong class="text-slate-800">Potash (K):</strong> 1.5 - 2.4%</div>
                        <div class="bg-slate-50 p-3 rounded border border-slate-200"><strong class="text-slate-800">Calcium (Ca):</strong> 0.5 - 1.0%</div>
                        <div class="bg-slate-50 p-3 rounded border border-slate-200"><strong class="text-slate-800">Magnesium (Mg):</strong> 0.2 - 0.3%</div>
                        <div class="bg-slate-50 p-3 rounded border border-slate-200"><strong class="text-slate-800">Sulphur (S):</strong> 0.4 - 0.5%</div>
                    </div>
                </section>

                <section>
                    <h2 class="text-xl font-bold text-slate-800 mb-4 border-l-4 border-purple-500 pl-4 flex items-center">
                        <i class="fa-solid fa-droplet mr-3 text-purple-500"></i>3. Automated Vermiwash Extraction
                    </h2>
                    <p class="mb-4">VermiTrack acts as a continuous bioreactor, extracting <strong>Vermiwash</strong>—a potent liquid plant growth regulator containing high amounts of enzymes, vitamins, and hormones.</p>
                    <div class="bg-slate-50 p-5 rounded-lg border border-slate-200">
                        <h3 class="font-bold text-slate-800 mb-2">Application Protocol:</h3>
                        <ul class="text-sm space-y-2 list-disc pl-5">
                            <li><strong>Growth Booster:</strong> Mix 1L of vermiwash with 7-10L of water and spray on leaves (upper and lower) in the evening.</li>
                            <li><strong>Disease Control:</strong> Mix 1L vermiwash + 1L cow urine + 10L water. Keep overnight before spraying (50-60L per bigha).</li>
                        </ul>
                    </div>
                </section>

                <section>
                    <h2 class="text-xl font-bold text-slate-800 mb-4 border-l-4 border-yellow-500 pl-4 flex items-center">
                        <i class="fa-solid fa-network-wired mr-3 text-yellow-500"></i>4. Cyber-Physical Methodology
                    </h2>
                    <p class="mb-4">VermiTrack digitizes the traditional layered composting method into a closed-loop CPS approach:</p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="bg-slate-50 p-4 rounded-lg border border-slate-200">
                            <h3 class="text-slate-800 font-bold mb-2"><i class="fa-solid fa-box mr-2 text-slate-500"></i>Hardware Layer (The Crate)</h3>
                            <p class="text-sm">Constructed from UV-resistant HDPE. Simulates optimal conditions via modular sensor arrays (moisture, DHT22 temp) and actuators (low-flow misting nozzles, 12V cooling fans).</p>
                        </div>
                        <div class="bg-slate-50 p-4 rounded-lg border border-slate-200">
                            <h3 class="text-slate-800 font-bold mb-2"><i class="fa-solid fa-recycle mr-2 text-emerald-500"></i>Feeding Mechanism</h3>
                            <p class="text-sm">Gravity-fed collector uses a motorized auger to dispense shredded waste based on acoustic activity levels of the worms, preventing overfeeding.</p>
                        </div>
                    </div>
                </section>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-4">
                    <section>
                        <h2 class="text-xl font-bold text-slate-800 mb-4 border-l-4 border-rose-500 pl-4 flex items-center">
                            <i class="fa-solid fa-scale-balanced mr-3 text-rose-500"></i>5. Feasibility
                        </h2>
                        <div class="space-y-4 text-sm">
                            <div>
                                <strong class="text-slate-800 block mb-1">Technical Viability:</strong>
                                Industrial-grade capacitive sensors avoid corrosion. Control loops run locally ensuring offline operation. Low power draw (20W solar/12V battery suitable).
                            </div>
                            <div>
                                <strong class="text-slate-800 block mb-1">Economic Practicality:</strong>
                                Reduces human monitoring time from 3 hours/week to 10 minutes/month. Provides dual yield: Solid compost and continuous Vermiwash extraction.
                            </div>
                        </div>
                    </section>

                    <section>
                        <h2 class="text-xl font-bold text-slate-800 mb-4 border-l-4 border-teal-500 pl-4 flex items-center">
                            <i class="fa-solid fa-arrow-trend-up mr-3 text-teal-500"></i>6. Scalability
                        </h2>
                        <div class="space-y-4 text-sm">
                            <div>
                                <strong class="text-slate-800 block mb-1">Modular Expansion:</strong>
                                Daisy-chain multiple crates for scale-up from small farmer to industrial facility under one interface.
                            </div>
                            <div>
                                <strong class="text-slate-800 block mb-1">Data Monetization:</strong>
                                Aggregated composting rate data can generate carbon credits for farmers as a secondary revenue stream.
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </div>

    </main>

    <!-- Custom Notification Toast -->
    <div id="toast-container" class="fixed bottom-6 right-6 z-50 flex flex-col gap-2 pointer-events-none"></div>

    <script>
        // --- UI Navigation Logic ---
        function switchTab(tabId) {
            document.getElementById('view-dashboard').classList.add('hidden');
            document.getElementById('view-docs').classList.add('hidden');
            
            document.getElementById('tab-dashboard').className = 'px-4 py-2 rounded-lg bg-white text-slate-600 hover:bg-slate-50 transition-colors border border-slate-200 shadow-sm font-medium';
            document.getElementById('tab-docs').className = 'px-4 py-2 rounded-lg bg-white text-slate-600 hover:bg-slate-50 transition-colors border border-slate-200 shadow-sm font-medium';
            
            if(tabId === 'dashboard') {
                document.getElementById('view-dashboard').classList.remove('hidden');
                document.getElementById('tab-dashboard').className = 'px-4 py-2 rounded-lg bg-vermi-primary text-white font-medium transition-colors shadow-md border border-transparent';
                if(envChart) envChart.resize();
            } else {
                document.getElementById('view-docs').classList.remove('hidden');
                document.getElementById('tab-docs').className = 'px-4 py-2 rounded-lg bg-vermi-primary text-white font-medium transition-colors shadow-md border border-transparent';
            }
        }

        // --- Logging System ---
        const terminalLog = document.getElementById('terminal-log');
        
        function addLog(message, type = 'info') {
            const time = new Date().toLocaleTimeString('en-US', { hour12: false });
            const p = document.createElement('p');
            
            let colorStr = 'text-slate-600';
            let prefix = '[SYS]';
            if (type === 'warn') { colorStr = 'text-orange-600'; prefix = '[WARN]'; }
            if (type === 'error') { colorStr = 'text-red-600'; prefix = '[ERR]'; }
            if (type === 'success') { colorStr = 'text-emerald-600'; prefix = '[OK]'; }
            if (type === 'action') { colorStr = 'text-blue-600'; prefix = '[CMD]'; }

            p.className = `flex gap-2 ${colorStr}`;
            p.innerHTML = `<span class="text-slate-400">[${time}]</span> <span class="font-bold">${prefix}</span> <span>${message}</span>`;
            
            terminalLog.appendChild(p);
            terminalLog.scrollTop = terminalLog.scrollHeight;
            
            if (terminalLog.children.length > 50) {
                terminalLog.removeChild(terminalLog.firstChild);
            }
        }

        function clearLogs() {
            terminalLog.innerHTML = '';
            addLog('Terminal cleared.', 'info');
        }

        function showToast(message, icon = 'fa-info-circle', colorClass = 'bg-slate-800') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `flex items-center p-4 rounded-lg shadow-lg text-white ${colorClass} transform transition-all duration-300 translate-y-10 opacity-0`;
            toast.innerHTML = `<i class="fa-solid ${icon} mr-3 text-xl"></i><span class="font-medium">${message}</span>`;
            
            container.appendChild(toast);
            
            setTimeout(() => { toast.classList.remove('translate-y-10', 'opacity-0'); }, 10);
            setTimeout(() => {
                toast.classList.add('translate-y-10', 'opacity-0');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function triggerActuator(name, btnId) {
            addLog(`Manual override triggered: ${name}`, 'action');
            showToast(`${name} activated`, 'fa-power-off', 'bg-slate-800');
            
            const btn = document.getElementById(btnId);
            const originalHtml = btn.innerHTML;
            btn.innerHTML = `<span class="text-white"><i class="fa-solid fa-circle-notch fa-spin mr-3"></i>Running...</span>`;
            btn.className = 'w-full flex justify-between items-center px-4 py-3 rounded-lg bg-vermi-primary border border-vermi-primary shadow-md transition-colors';
            
            setTimeout(() => {
                btn.innerHTML = originalHtml;
                btn.className = 'w-full flex justify-between items-center px-4 py-3 rounded-lg bg-white hover:bg-slate-50 border border-slate-200 shadow-sm transition-colors group';
                addLog(`${name} sequence completed.`, 'success');
            }, 2000);
        }

        // --- 3D Visualization & Labeling System ---
        let scene, camera, renderer, controls;
        const sceneLabels = []; // Stores { pos: Vector3, element: HTMLElement }

        window.onload = function () {
            initThreeJS();
            initChartJS();
            startTelemetrySimulation();
            addLog('VermiTrack OS v1.0.0-beta Initialized', 'success');
            addLog('Establishing connection to VermiTrack Cloud...', 'info');
            setTimeout(() => addLog('Connection established. Telemetry sync active.', 'success'), 1000);
        };

        function createLabel(text, iconClass, position) {
            const el = document.createElement('div');
            el.className = 'scene-label';
            el.innerHTML = `<i class="fa-solid ${iconClass}"></i> ${text}`;
            document.getElementById('labels-container').appendChild(el);
            sceneLabels.push({
                pos: new THREE.Vector3(position[0], position[1], position[2]),
                element: el
            });
        }

        function updateLabels() {
            const container = document.getElementById('canvas-container');
            const halfWidth = container.clientWidth / 2;
            const halfHeight = container.clientHeight / 2;

            sceneLabels.forEach(label => {
                // Get vector coordinate
                const vector = label.pos.clone();
                // Project it to 2D screen space
                vector.project(camera);

                // Check if behind camera
                if (vector.z > 1) {
                    label.element.style.opacity = '0';
                    return;
                }

                // Calculate CSS coordinates
                const x = (vector.x * halfWidth) + halfWidth;
                const y = -(vector.y * halfHeight) + halfHeight;

                label.element.style.left = `${x}px`;
                label.element.style.top = `${y}px`;
                label.element.style.opacity = '1';
            });
        }

        function initThreeJS() {
            const container = document.getElementById('canvas-container');
            if(!container) return;

            scene = new THREE.Scene();
            // Light background
            scene.background = new THREE.Color(0xf8fafc);
            scene.fog = new THREE.FogExp2(0xf8fafc, 0.015);

            camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
            camera.position.set(14, 12, 18);

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            // Tonemapping for better materials
            renderer.toneMapping = THREE.ACESFilmicToneMapping;
            renderer.toneMappingExposure = 1.0;
            container.insertBefore(renderer.domElement, document.getElementById('labels-container'));

            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.maxPolarAngle = Math.PI / 2 - 0.05;
            controls.minDistance = 8;
            controls.maxDistance = 35;
            controls.target.set(0, 1, 0);

            // Smoother Lighting for light theme
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambientLight);

            const hemiLight = new THREE.HemisphereLight(0xffffff, 0x444444, 0.4);
            hemiLight.position.set(0, 20, 0);
            scene.add(hemiLight);

            const dirLight = new THREE.DirectionalLight(0xffffff, 0.8);
            dirLight.position.set(10, 20, 10);
            dirLight.castShadow = true;
            dirLight.shadow.mapSize.width = 2048;
            dirLight.shadow.mapSize.height = 2048;
            dirLight.shadow.camera.near = 0.5;
            dirLight.shadow.camera.far = 50;
            dirLight.shadow.camera.left = -15;
            dirLight.shadow.camera.right = 15;
            dirLight.shadow.camera.top = 15;
            dirLight.shadow.camera.bottom = -15;
            scene.add(dirLight);

            const systemGroup = new THREE.Group();

            // 1. The Crate (High-quality translucent HDPE)
            const w=10, h=6, d=8, t=0.2;
            const crateMat = new THREE.MeshPhysicalMaterial({
                color: 0x10b981,
                metalness: 0.1,
                roughness: 0.2,
                transparent: true,
                transmission: 0.8, // glass-like
                ior: 1.5,
                thickness: 0.5,
                opacity: 1,
                side: THREE.DoubleSide
            });

            // Assemble crate walls smoothly
            const bottom = new THREE.Mesh(new THREE.BoxGeometry(w, t, d), crateMat);
            bottom.position.y = -h/2;
            bottom.receiveShadow = true;
            systemGroup.add(bottom);

            const front = new THREE.Mesh(new THREE.BoxGeometry(w, h, t), crateMat);
            front.position.set(0, 0, d/2);
            front.castShadow = true; front.receiveShadow = true;
            systemGroup.add(front);

            const back = new THREE.Mesh(new THREE.BoxGeometry(w, h, t), crateMat);
            back.position.set(0, 0, -d/2);
            back.castShadow = true; back.receiveShadow = true;
            systemGroup.add(back);

            const left = new THREE.Mesh(new THREE.BoxGeometry(t, h, d), crateMat);
            left.position.set(-w/2, 0, 0);
            left.castShadow = true; left.receiveShadow = true;
            systemGroup.add(left);

            const right = new THREE.Mesh(new THREE.BoxGeometry(t, h, d), crateMat);
            right.position.set(w/2, 0, 0);
            right.castShadow = true; right.receiveShadow = true;
            systemGroup.add(right);

            // Crate Rim
            const rimMat = new THREE.MeshStandardMaterial({color: 0x059669, roughness: 0.4});
            const rimFront = new THREE.Mesh(new THREE.BoxGeometry(w+0.6, 0.4, 0.4), rimMat);
            rimFront.position.set(0, h/2, d/2+0.1);
            rimFront.castShadow = true;
            systemGroup.add(rimFront);
            const rimBack = new THREE.Mesh(new THREE.BoxGeometry(w+0.6, 0.4, 0.4), rimMat);
            rimBack.position.set(0, h/2, -d/2-0.1);
            rimBack.castShadow = true;
            systemGroup.add(rimBack);
            const rimLeft = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.4, d-0.2), rimMat);
            rimLeft.position.set(-w/2-0.1, h/2, 0);
            rimLeft.castShadow = true;
            systemGroup.add(rimLeft);
            const rimRight = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.4, d-0.2), rimMat);
            rimRight.position.set(w/2+0.1, h/2, 0);
            rimRight.castShadow = true;
            systemGroup.add(rimRight);

            // 2. The Soil (Compost) - richer color, softer look
            const soilMat = new THREE.MeshStandardMaterial({
                color: 0x4e342e, 
                roughness: 1.0,
                metalness: 0.0
            });
            const soilH = 4.5;
            const soil = new THREE.Mesh(new THREE.BoxGeometry(w-0.5, soilH, d-0.5, 8, 2, 8), soilMat);
            soil.position.y = -h/2 + soilH/2 + 0.1;
            soil.receiveShadow = true;
            soil.castShadow = true;
            systemGroup.add(soil);

            // 3. The Worms (Smoother cylinders)
            const wormMat = new THREE.MeshStandardMaterial({ color: 0xec4899, roughness: 0.3, metalness: 0.1 });
            const soilTopY = soil.position.y + soilH/2;
            
            for(let i=0; i<45; i++) {
                const r = 0.06 + Math.random()*0.04;
                const len = 0.6 + Math.random()*0.6;
                const wormGeo = new THREE.CylinderGeometry(r, r, len, 16); // smoother
                const worm = new THREE.Mesh(wormGeo, wormMat);
                worm.position.set(
                    (Math.random() - 0.5) * (w - 2),
                    soilTopY + r/2,
                    (Math.random() - 0.5) * (d - 2)
                );
                worm.rotation.set(Math.PI/2, Math.random()*Math.PI, (Math.random()-0.5)*0.5);
                worm.castShadow = true;
                systemGroup.add(worm);
            }

            // 4. Electronics Box (ESP32 / ECU)
            const elecMat = new THREE.MeshStandardMaterial({ color: 0xe2e8f0, metalness: 0.2, roughness: 0.5 });
            const elecBox = new THREE.Mesh(new THREE.BoxGeometry(1.5, 2.5, 1), elecMat);
            elecBox.position.set(w/2 + 0.5 + t/2, 1, 0);
            elecBox.castShadow = true;
            systemGroup.add(elecBox);

            const antGeo = new THREE.CylinderGeometry(0.04, 0.04, 1.5, 16);
            const antMat = new THREE.MeshStandardMaterial({color: 0x334155, roughness: 0.7});
            const antenna = new THREE.Mesh(antGeo, antMat);
            antenna.position.set(w/2 + 0.5 + t/2, 2.5, 0);
            antenna.castShadow = true;
            systemGroup.add(antenna);

            const ledMat = new THREE.MeshBasicMaterial({ color: 0x10b981 });
            const led = new THREE.Mesh(new THREE.SphereGeometry(0.1, 16, 16), ledMat);
            led.position.set(w/2 + 1.05, 1.5, 0.3);
            systemGroup.add(led);

            const screenMat = new THREE.MeshBasicMaterial({ color: 0x0f172a });
            const screen = new THREE.Mesh(new THREE.PlaneGeometry(0.8, 0.5), screenMat);
            screen.position.set(w/2 + 1.26, 0.8, 0);
            screen.rotation.y = Math.PI/2;
            systemGroup.add(screen);

            // 5. Sensor Array (Probe into soil)
            const probeGeo = new THREE.CylinderGeometry(0.05, 0.05, 3, 16);
            const probeMat = new THREE.MeshStandardMaterial({color: 0x94a3b8, metalness: 0.8, roughness: 0.2});
            const probe = new THREE.Mesh(probeGeo, probeMat);
            probe.position.set(2, soilTopY, 0);
            probe.castShadow = true;
            systemGroup.add(probe);
            // Sensor Box Top
            const sensorBoxMat = new THREE.MeshStandardMaterial({color: 0xf1f5f9});
            const sensorBox = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.4, 0.6), sensorBoxMat);
            sensorBox.position.set(2, soilTopY + 1.5, 0);
            sensorBox.castShadow = true;
            systemGroup.add(sensorBox);

            // 6. Feeding Auger
            const augerGroup = new THREE.Group();
            const hopperMat = new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.4, metalness: 0.2 });
            const hopper = new THREE.Mesh(new THREE.CylinderGeometry(1.5, 0.5, 2, 32), hopperMat);
            hopper.position.set(-2, h/2 + 1.5, 0);
            hopper.castShadow = true;
            augerGroup.add(hopper);

            const pipe = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.4, 2, 16), hopperMat);
            pipe.position.set(-2, h/2 + 0.2, 0);
            pipe.castShadow = true;
            augerGroup.add(pipe);
            systemGroup.add(augerGroup);

            scene.add(systemGroup);

            // Floor plane
            const floorMat = new THREE.MeshStandardMaterial({ color: 0xe2e8f0, roughness: 0.8 });
            const floor = new THREE.Mesh(new THREE.PlaneGeometry(100, 100), floorMat);
            floor.rotation.x = -Math.PI / 2;
            floor.position.y = -h/2 - 0.5;
            floor.receiveShadow = true;
            scene.add(floor);

            // === Add Visual Labels ===
            // Note: Positions are relative to the world, rotating with the group in the animation
            createLabel('HDPE Crate', 'fa-box', [0, -2, 4.2]);
            createLabel('Compost / Soil', 'fa-seedling', [0, 0, 0]);
            createLabel('Organic Feeder', 'fa-recycle', [-2, 5.5, 0]);
            createLabel('Main ECU', 'fa-microchip', [6.5, 1.5, 0]);
            createLabel('Eisenia foetida', 'fa-bug', [2.5, 2.5, -2.5]);
            createLabel('Sensor Array', 'fa-satellite-dish', [2, 4.2, 0]);

            // Animation Loop
            let clock = new THREE.Clock();
            function animate() {
                requestAnimationFrame(animate);
                
                const time = clock.getElapsedTime();

                // Slow rotation of the system
                systemGroup.rotation.y = Math.sin(time * 0.2) * 0.5; // gentle rocking/rotation

                // Update labels pos relative to rotated group
                sceneLabels.forEach((lbl, index) => {
                    // Base positions
                    const bases = [
                        [0, -2, 4.2], [-1.5, 0, 1.5], [-2, 5.5, 0], [6.5, 1.5, 0], [2.5, 2.5, -2.5], [2, 4.2, 0]
                    ];
                    // Apply group rotation to base positions
                    const localPos = new THREE.Vector3(...bases[index]);
                    localPos.applyMatrix4(systemGroup.matrixWorld);
                    lbl.pos.copy(localPos);
                });
                
                updateLabels();

                // LED Blink effect
                ledMat.color.setHex(Math.floor(time * 2) % 2 === 0 ? 0x10b981 : 0x0f172a);

                controls.update();
                renderer.render(scene, camera);
            }
            
            animate();

            // Handle Resize
            window.addEventListener('resize', () => {
                camera.aspect = container.clientWidth / container.clientHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(container.clientWidth, container.clientHeight);
            });
        }

        // --- Chart.js Setup ---
        let envChart;
        function initChartJS() {
            const ctx = document.getElementById('envChart').getContext('2d');
            
            const labels = Array.from({length: 12}, (_, i) => `${12-i}h ago`).reverse();
            const moisureData = [62, 63, 61, 65, 66, 64, 68, 69, 67, 70, 68, 68.5];
            const tempData = [21.5, 21.8, 22.0, 22.1, 22.5, 22.8, 22.9, 23.0, 22.6, 22.4, 22.3, 22.4];

            envChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Moisture (%)',
                            data: moisureData,
                            borderColor: '#3b82f6',
                            backgroundColor: 'rgba(59, 130, 246, 0.1)',
                            borderWidth: 2,
                            tension: 0.4,
                            fill: true,
                            yAxisID: 'y'
                        },
                        {
                            label: 'Temperature (°C)',
                            data: tempData,
                            borderColor: '#f97316',
                            backgroundColor: 'transparent',
                            borderWidth: 2,
                            tension: 0.4,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { labels: { color: '#475569', font: { family: 'Inter', weight: '500' } } }
                    },
                    scales: {
                        x: {
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            ticks: { color: '#64748b' }
                        },
                        y: {
                            type: 'linear', display: true, position: 'left',
                            title: { display: true, text: 'Moisture %', color: '#3b82f6', font: {weight: 'bold'} },
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            ticks: { color: '#64748b' },
                            min: 50, max: 100
                        },
                        y1: {
                            type: 'linear', display: true, position: 'right',
                            title: { display: true, text: 'Temp °C', color: '#ea580c', font: {weight: 'bold'} },
                            grid: { drawOnChartArea: false },
                            ticks: { color: '#64748b' },
                            min: 15, max: 35
                        }
                    }
                }
            });
        }

        // --- Live Telemetry Simulation ---
        function startTelemetrySimulation() {
            let moisture = 68.5;
            let temp = 22.4;
            let feed = 42;
            
            setInterval(() => {
                moisture += (Math.random() - 0.5) * 0.5;
                temp += (Math.random() - 0.5) * 0.2;
                
                if (moisture > 75) moisture = 75;
                if (moisture < 55) moisture = 55;
                if (temp > 28) temp = 28;
                if (temp < 18) temp = 18;

                document.getElementById('val-moisture').innerText = moisture.toFixed(1) + '%';
                document.getElementById('bar-moisture').style.width = moisture + '%';
                
                document.getElementById('val-temp').innerText = temp.toFixed(1) + '°C';
                let tempPercent = ((temp - 15) / 20) * 100;
                document.getElementById('bar-temp').style.width = tempPercent + '%';

                const mBar = document.getElementById('bar-moisture');
                if (moisture < 60) {
                    mBar.className = "bg-orange-500 h-full rounded-full transition-all duration-500";
                    if (Math.random() < 0.1) addLog(`Moisture dropping (${moisture.toFixed(1)}%). Auto-misting recommended.`, 'warn');
                } else if (moisture > 70) {
                    mBar.className = "bg-blue-300 h-full rounded-full transition-all duration-500";
                } else {
                    mBar.className = "bg-blue-500 h-full rounded-full transition-all duration-500";
                }

                const tBar = document.getElementById('bar-temp');
                if (temp > 25) {
                    tBar.className = "bg-red-500 h-full rounded-full transition-all duration-500";
                    if (Math.random() < 0.05) {
                        addLog(`Temperature high (${temp.toFixed(1)}°C). Activating cooling fan.`, 'action');
                        triggerActuator('Auto-Cooling Fan', 'btn-fan');
                    }
                } else {
                    tBar.className = "bg-orange-500 h-full rounded-full transition-all duration-500";
                }

                const acousticBars = document.getElementById('acoustic-bars').children;
                let activeCount = Math.floor(Math.random() * 4) + 1;
                for(let i=0; i<5; i++) {
                    if (i < activeCount) {
                        acousticBars[i].className = "bg-purple-500 flex-1 rounded-full animate-pulse shadow-[0_0_8px_rgba(168,85,247,0.5)]";
                    } else {
                        acousticBars[i].className = "bg-slate-200 flex-1 rounded-full";
                    }
                }

                if (Math.random() < 0.1 && envChart) {
                    envChart.data.datasets[0].data.shift();
                    envChart.data.datasets[0].data.push(moisture);
                    envChart.data.datasets[1].data.shift();
                    envChart.data.datasets[1].data.push(temp);
                    envChart.update();
                }

            }, 2000);
        }

    </script>
</body>
</html>
