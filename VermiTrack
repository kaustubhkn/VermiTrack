                            </button>
                            <button onclick="triggerActuator('Feed Auger', 'btn-feed')" id="btn-feed" class="w-full flex justify-between items-center px-4 py-3 rounded-lg bg-white hover:bg-emerald-50 border border-slate-200 shadow-sm transition-colors group">
                                <span class="text-slate-700 font-medium group-hover:text-emerald-600 transition-colors"><i class="fa-solid fa-gear mr-3 text-emerald-500"></i>Organic Auger</span>
