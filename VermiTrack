                            <button onclick="triggerActuator('Cooling Fan', 'btn-fan')" id="btn-fan" class="w-full flex justify-between items-center px-4 py-3 rounded-lg bg-white hover:bg-orange-50 border border-slate-200 shadow-sm transition-colors group">
